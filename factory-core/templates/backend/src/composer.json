{
	"name": "labor-digital/{{PROJECT_NAME}}-backend",
	"description": "TYPO3 v13 backend for {{PROJECT_LABEL}}",
	"type": "project",
	"license": "GPL-2.0-or-later",
	"minimum-stability": "dev",
	"prefer-stable": true,
	"repositories": [
		{
			"type": "path",
			"url": "../modules/typo3-extension",
			"options": {
				"symlink": true
			}
		},
		{
			"type": "path",
			"url": "packages/client_sitepackage",
			"options": {
				"symlink": true
			}
		}
	],
	"require": {
		"php": "^8.4",
		"typo3/cms-base-distribution": "^13.4",
		"typo3/cms-backend": "^13.4",
		"typo3/cms-frontend": "^13.4",
		"typo3/cms-install": "^13.4",
		"friendsoftypo3/content-blocks": "^1.3.20",
		"friendsoftypo3/headless": "^v4.7.3",
		"netzbewegung/nb-headless-content-blocks": "^0.0.21",
		"labor-digital/factory-core": "@dev",
		"labor-digital/client-sitepackage": "@dev"
	},
	"extra": {
		"typo3/cms": {
			"web-dir": "public",
			"extension-dir": "packages"
		}
	},
	"config": {
		"allow-plugins": {
			"typo3/cms-composer-installers": true,
			"typo3/class-alias-loader": true
		},
		"sort-packages": true
	}
}
