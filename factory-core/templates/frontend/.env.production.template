# Fly.io runtime environment for the Nuxt SSR frontend.
# These are set via `flyctl secrets set` during pipeline provisioning and
# can be inspected with `flyctl secrets list --app {{PROJECT_NAME}}-frontend`.
# This file is documentation — it is not consumed at runtime.

# Base URL of the shared TYPO3 instance (or per-client backend).
# Matches the env var read by templates/frontend/src/nuxt.config.ts.
TYPO3_API_BASE_URL=https://your-backend.example.com

# Nitro listen config — the Dockerfile.production sets these; only override
# if you're deploying somewhere other than Fly.io's default internal_port=3000.
NITRO_HOST=0.0.0.0
NITRO_PORT=3000
